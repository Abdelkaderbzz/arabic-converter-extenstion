{
  "manifest_version": 3,
  "name": "Arabizzi",
  "version": "1.3.0",
  "description": "Convert colloquial Arabic (Latin/Arabizi) into Arabic script, Fusha, English, or French.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arabizzi",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"]
}
